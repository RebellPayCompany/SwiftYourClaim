{% extends 'layout_front.html.twig' %}

{% block body %}
    <div class="container">
        <div class="registration">
            <div class="box box-primary">
                <div class="box-header">
                    <h3 class="text-uppercase box-title">{{ 'global.registration'|trans }}</h3>
                </div>
                <div class="box-body">
                    <h2 class="text-center">{{ 'global.step'|trans }} 1 <span class="small">/ 5</span></h2>
                    <h3 class="text-center">{{ 'global.create_account'|trans }}</h3>
                    <div class="row">
                        <div class="col-sm-offset-3 col-sm-6">
                            {{ form_start(form) }}
                            <div class="form-group">
                                {{ form_widget(form.firstName) }}
                                {{ form_errors(form.firstName) }}
                            </div>
                            <div class="form-group">
                                {{ form_widget(form.lastName) }}
                                {{ form_errors(form.lastName) }}
                            </div>
                            <div class="form-group">
                                {{ form_widget(form.email) }}
                                {{ form_errors(form.email) }}
                            </div>
                            <div class="form-group">
                                {{ form_widget(form.plainPassword.first) }}
                                {{ form_errors(form.plainPassword.first) }}
                            </div>
                            <div class="form-group">
                                {{ form_widget(form.plainPassword.second) }}
                                {{ form_errors(form.plainPassword.second) }}
                            </div>
                            <div class="text-center margin-top-40 margin-bottom-80 max-width">
                                {{ form_row(form.submit) }}
                            </div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% extends 'layout_front.html.twig' %}

{% block body %}
    <div class="container">
        <div class="registration">
            <div class="box box-primary">
                <div class="box-header">
                    <h3 class="text-uppercase box-title">{{ 'global.registration'|trans }}</h3>
                </div>
                <div class="box-body">
                    <h2 class="text-center">{{ 'global.step'|trans }} 2 <span class="small">/ 5</span></h2>
                    <h3 class="text-center">{{ 'global.fill_organization_data'|trans }}</h3>
                    <div class="row margin-top-20">
                        <div class="col-sm-offset-3 col-sm-6">
                            {{ form_start(form) }}
                            <div class="form-group">
                                {{ form_widget(form.krs) }}
                                {{ form_errors(form.krs) }}
                            </div>
                            <div class="margin-top-20 margin-bottom-80 pull-right width-200">
                                {{ form_row(form.submit) }}
                            </div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
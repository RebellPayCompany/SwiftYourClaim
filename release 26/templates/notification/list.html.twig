{% extends 'layout_panel.html.twig' %}

{% block head %}
    {{ 'global.notification'|trans }}
{% endblock %}

{% block head_small %}
    {{ 'global.user2'|trans }}
{% endblock %}

{% block body %}
    <div class="box box-primary">
        <div class="box-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <tr class="thpt">
                        <th class="thpt">
                            {{ knp_pagination_sortable(notifications, 'global.title'|trans, 'n.title') }}
                        </th>
                        <th class="thpt">
                            {{ knp_pagination_sortable(notifications, 'global.date'|trans, 'n.date') }}
                        </th>
                        <th class="thpt"></th>
                    </tr>
                    {% for notification in notifications %}
                        <tr>
                            <td>
                                <i class="fa fa-file-text-o text-danger"></i>
                                {{ notification.title }}
                            </td>
                            <td>{{ notification.date|date("d.m.Y, H:i") }}</td>
                            <td class="text-right">
                                <a href="javascript:void(0)" class="notification-show-details"
                                   data-id="{{ notification.id }}">
                                    <i class="fa fa-commenting-o text-info"></i>
                                    {{ 'global.view_details'|trans }}
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3">{{ 'global.lack_notification'|trans }}</td>
                        </tr>
                    {% endfor %}
                </table>

                <div class="text-right">
                    {{ knp_pagination_render(notifications) }}
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="notificationModal" tabindex="-1" role="dialog" aria-labelledby="notificationModalLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="modal-body-text margin-top-50 margin-bottom-60"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(".notification-show-details").click(function () {
            var id = $(this).data("id");
            var url = Routing.generate('notification_view', {'notification': id});

            $.ajax({
                method: "POST",
                url: url,
            }).done(function (msg) {
                $("#notificationModal .modal-body-text").html(msg);
                $("#notificationModal").modal();
            });
        })
    </script>
{% endblock %}
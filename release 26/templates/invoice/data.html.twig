{% extends 'layout_panel.html.twig' %}

{% block head %}
    {{ 'global.invoice_data'|trans }}
{% endblock %}

{% block body %}
    <div class="box box-primary">
        <div class="box-body">
            <div class="row">
                {{ form_start(form) }}
                <div class="col-sm-7">
                    <div class="form-group">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.street) }}
                        {{ form_widget(form.street) }}
                        {{ form_errors(form.street) }}
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                {{ form_label(form.houseNo) }}
                                {{ form_widget(form.houseNo) }}
                                {{ form_errors(form.houseNo) }}
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                {{ form_label(form.apartmentNo) }}
                                {{ form_widget(form.apartmentNo) }}
                                {{ form_errors(form.apartmentNo) }}
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_label(form.zipCode) }}
                        {{ form_widget(form.zipCode) }}
                        {{ form_errors(form.zipCode) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.city) }}
                        {{ form_widget(form.city) }}
                        {{ form_errors(form.city) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.nip) }}
                        {{ form_widget(form.nip) }}
                        {{ form_errors(form.nip) }}
                    </div>

                    <div class="pull-right width-200">
                        <button type="submit" class="btn btn-primary">
                            <span class="fa fa-check"></span>
                            {{ 'global.save'|trans }}
                        </button>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
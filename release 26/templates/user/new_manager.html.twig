{% extends 'layout_panel.html.twig' %}
{% form_theme form _self %}

{% block head %}
    {{ 'global.add'|trans }}
{% endblock %}

{% block head_small %}
    {{ 'global.manager2'|trans }}
{% endblock %}

{% block body %}
    <div class="box box-primary">
        <div class="box-body">

            {{ form_start(form) }}
            <div class="row">
                <div class="col-sm-7">
                    <div class="form-group">
                        {{ form_label(form.firstName) }}
                        {{ form_widget(form.firstName) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.lastName) }}
                        {{ form_widget(form.lastName) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.manager.pesel) }}
                        {{ form_widget(form.manager.pesel) }}
                        {{ form_errors(form.manager.pesel) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.manager.position) }}
                        {{ form_widget(form.manager.position) }}
                        {{ form_errors(form.manager.position) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.manager.phone) }}
                        {{ form_widget(form.manager.phone) }}
                        {{ form_errors(form.manager.phone) }}
                    </div>
                    <div class="pull-right">
                        {{ form_widget(form.submit) }}
                    </div>
                </div>
                {% if form.access is defined %}
                    <div class="col-sm-5">
                        {{ form_row(form.access) }}
                    </div>
                {% endif %}
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block checkbox_widget %}
    {% spaceless %}
        <input type="checkbox" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
        <label for="{{ id }}">{{ label|trans({}, translation_domain) }}</label>
    {% endspaceless %}
{% endblock checkbox_widget %}
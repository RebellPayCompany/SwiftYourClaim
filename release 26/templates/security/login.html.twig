{% extends 'layout_front.html.twig' %}

{% block title %}Logowanie{% endblock %}

{% block body %}
    <div class="container">
        <div class="registration">
            <div class="box box-primary">
                <div class="box-header">
                    <h3 class="text-uppercase box-title">{{ 'global.log_in_text'|trans }}</h3>
                </div>

                <div class="box-body">
                    <div class="margin-top-10">&nbsp;</div>
                    <div class="row">
                        <div class="col-sm-offset-3 col-sm-6">
                            <form method="post">
                                {% if error %}
                                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                {% endif %}

                                <div class="form-group">
                                    <label for="inputEmail" class="sr-only">{{ 'global.email'|trans }}</label>
                                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                                           class="form-control"
                                           placeholder="{{ 'global.email'|trans }}" required autofocus>
                                </div>

                                <div class="form-group">
                                    <label for="inputPassword" class="sr-only">{{ 'global.password'|trans }}</label>
                                    <input type="password" name="password" id="inputPassword" class="form-control"
                                           placeholder="{{ 'global.password'|trans }}" required>
                                </div>

                                <div class="form-check">
                                    <input type="checkbox" id="data_remember" name="_remember_me" class="form-check-input">
                                    <label class="form-check-label" for="data_remember">{{ 'global.remember_me'|trans }}</label>
                                </div>

                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                <div class="text-center margin-bottom-30 max-width">
                                    <button class="btn btn-primary" type="submit">
                                        {{ 'global.log_in'|trans }}
                                    </button>
                                </div>
                                <div class="text-center margin-top-20 register-as">
                                    <a href="{{ path('user_registration') }}">
                                        <span class="fa fa-user-circle-o"></span>
                                        {{ 'global.register_as_emitent'|trans }}
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

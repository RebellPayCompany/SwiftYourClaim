{% extends 'layout_panel.html.twig' %}

{% block head %}
    <h1>{{ 'global.my_current_report'|trans }}</h1>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-sm-10">
            <div class="panel  panel-primary">
                <div class="panel-body form2">
                    {{ form_start(form) }}
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                {{ form_label(form.pesel) }}
                                {{ form_widget(form.pesel) }}
                                {{ form_errors(form.pesel) }}
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group margin-top-50">
                                {{ form_widget(form.noPesel) }}
                            </div>
                        </div>
                    </div>
                    <div class="text-right margin-top-40">
                        {{ form_widget(form.submit) }}
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            $("#report_pesel_noPesel").click(function () {
                if ($(this).is(':checked')) {
                    $("#report_pesel_submit").html("{{ 'global.go_further'|trans }}");
                    $("#report_pesel_pesel").removeAttr("required");
                    $("#report_pesel_pesel").val("");
                } else {
                    $("#report_pesel_submit").html("{{ 'global.get_data_from_krs'|trans }}");
                    $("#report_pesel_pesel").attr("required", "required");
                }
            });
        });
    </script>
{% endblock %}
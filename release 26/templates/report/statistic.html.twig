{% extends 'layout_panel.html.twig' %}

{% block head %}
    {{ 'global.statistic'|trans }}
{% endblock %}

{% block head_small %}
    <span class="text-lowercase">{{ 'global.reports'|trans }}</span>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/morris.css') }}">
{% endblock %}

{% block body %}
    <div class="box box-primary">
        <div class="box-body">
            <p>{{ 'global.number_of_reports_during_the_month'|trans }}</p>
            <div class="chart" id="revenue-chart" style="height: 300px;"></div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/morris.js') }}"></script>
    <script src="{{ asset('js/raphael.js') }}"></script>

    <script>
        $(function () {
            "use strict";

            // AREA CHART
            var area = new Morris.Area({
                element: 'revenue-chart',
                resize: true,
                data: [
                    {% for key, item in result %}
                    { y: '{{ key }}', a: {{ item }} },
                    {% endfor %}
                ],
                xkey: 'y',
                ykeys: ['a'],
                labels: ['Ilość raportów'],
                fillOpacity: 0.2,
                lineWidth:1,
                lineColors: ['rgba(38,198,218,1)'],
                hideHover: 'auto'
            });
        });
    </script>
{% endblock %}
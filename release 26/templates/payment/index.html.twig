{% extends 'layout_panel.html.twig' %}

{% block head %}
    {{ 'global.payment'|trans }}
{% endblock %}

{% block body %}
    <div class="box box-primary">
        <div class="box-body">
            <div class="products" style="margin-bottom: 0">
                <div class="product-details">
                    {% if premium %}
                        <p style="font-size: 120%" class="margin-bottom">
                            Posiadasz <b>konto Premium</b>.
                        </p>

                        <div class="table-responsive">
                            <table class="table">
                                <tr class="thpt">
                                    <th>{{ 'global.product'|trans }}</th>
                                    <th>Okres</th>
                                    <th></th>
                                </tr>
                                <tr>
                                    <td>{{ name }}</td>
                                    <td>{{ termStart }} - {{ termEnd }}</td>
                                    <td></td>
                                </tr>
                            </table>
                        </div>
                    {% else %}

                        <p style="font-size: 120%" class="margin-bottom">
                            Posiadasz <b>konto podstawowe</b>. Aby uzyskać dodatkowe profity wykup <b>konto premium</b>.
                        </p>

                        <div class="table-responsive">
                            <table class="table">
                                <tr class="thpt">
                                    <th>{{ 'global.product'|trans }}</th>
                                    <th>Cena</th>
                                    <th></th>
                                </tr>
                                <tr>
                                    <td>{{ name }}</td>
                                    <td>{{ price }} / rok</td>
                                    <td>
                                        <div class="product-buttons">
                                            <div class="product-buttons-buy">
                                                <form method="POST" action="https://secure.payu.com/api/v2_1/orders">
                                                    {% for key,value in payU %}
                                                        <input type="hidden" name="{{ key }}" value="{{ value }}">
                                                    {% endfor %}
                                                    <input type="hidden" name="OpenPayu-Signature" type="hidden"
                                                           value="{{ signature }}">
                                                    <button type="submit" formtarget="_blank" class="btn btn-danger">
                                                        Opłać konto
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="row">
                <div class="col-sm-6">
                    {% if user.invoiceGenerate %}
                        {% if user.invoiceData %}
                            <a href="{{ path('payment_generate_invoice') }}" class="btn btn-primary">Wygeneruj fakturę</a>
                        {% else %}
                            <span class="glyphicon glyphicon-exclamation-sign text-danger" style="font-size: 120%"></span>
                            <span class="text-danger">Uzupełnij dane do faktury, aby wygenerować fakturę</span>
                        {% endif %}
                    {% endif %}
                </div>
                <div class="col-sm-6 text-right">
                    <a href="{{ path('invoice_data') }}" class="btn btn-success">Zmień dane do faktury</a>
                </div>
            </div>

            {% if invoices|length %}
                <p style="font-size: 120%; margin-top: 30px">{{ 'global.invoices'|trans }}</p>

                <div class="table-responsive">
                    <table class="table">
                        <tr class="thpt">
                            <th>{{ 'global.invoice_number'|trans }}</th>
                            <th>{{ 'global.date'|trans }}</th>
                            <th></th>
                        </tr>
                        {% for invoice in invoices %}
                            <tr>
                                <td>{{ invoice.number }}</td>
                                <td>{{ invoice.date|date("d.m.y") }}</td>
                                <td class="text-right">
                                    <a href="{{ asset('uploads/invoices/'~invoice.file) }}" class="btn btn-success" target="_blank">
                                        <span class="fa fa-search-plus"></span>
                                        Zobacz fakturę
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}